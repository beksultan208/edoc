# ============================================================
# ГосДок — переменные окружения (.env.example)
# Скопируйте в .env и заполните значения
# ============================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-very-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- База данных PostgreSQL ---
DATABASE_URL=postgres://gosdoc_user:gosdoc_pass@db:5432/gosdoc

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- AWS S3 / Yandex Object Storage ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=gosdoc-documents
AWS_S3_REGION_NAME=us-east-1
# Для Yandex Object Storage:
# AWS_S3_ENDPOINT_URL=https://storage.yandexcloud.net

# --- Email (SMTP) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=ГосДок <your-gmail@gmail.com>

# --- OpenAI / LLM ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Sentry ---
SENTRY_DSN=

# --- Celery ---
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- PostgreSQL (для docker-compose) ---
POSTGRES_DB=gosdoc
POSTGRES_USER=gosdoc_user
POSTGRES_PASSWORD=gosdoc_pass
